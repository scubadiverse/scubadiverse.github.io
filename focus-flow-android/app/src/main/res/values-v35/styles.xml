<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 15 (API 35) forces edge-to-edge by default, which draws the WebView
         under the status and navigation bars. Opt out so the system draws the bars
         normally and no app content is ever hidden behind them. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>
